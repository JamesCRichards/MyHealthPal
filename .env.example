# Backend: use real AI for Health Pal chat (required for full AI, not programmed replies).
# Easiest — FREE Groq key (no credit card): https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_key_here

# Or use OpenAI (platform.openai.com/api-keys) or OpenRouter (openrouter.ai/keys)
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Optional: custom model for chat (default: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: use a custom OpenAI-compatible endpoint instead (e.g. proxy, Azure)
# CURSOR_API_KEY=your_key_here
# CURSOR_API_BASE=https://api.cursor.com

# Optional: Groq model (default: llama-3.3-70b-versatile)
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Frontend: URL of the Health Pal API server (so the React app can call /api/chat and /api/reminders)
REACT_APP_API_URL=http://localhost:3001

# Optional: Pal speaks replies and reminders (TTS). Get key at elevenlabs.io
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
