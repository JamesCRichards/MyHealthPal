# Backend (server): Cursor API key for Health Pal chat (optional; app works with built-in fallback if unset)
CURSOR_API_KEY=crsr_your_key_here

# Optional: use an OpenAI-compatible proxy for Cursor (e.g. cursor-api-proxy). Default: https://api.cursor.com
# CURSOR_API_BASE=https://your-proxy/v1

# Frontend: URL of the Health Pal API server (so the React app can call /api/chat and /api/reminders)
REACT_APP_API_URL=http://localhost:3001
